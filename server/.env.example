# Conexión a MongoDB Atlas
MONGO_URI=mongodb+srv://<usuario>:<password>@cluster.mongodb.net/<dbname>

# Secreto JWT — genera uno con:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<string_aleatorio_64_bytes>

# Entorno
NODE_ENV=development

# Habilitar endpoint de setup inicial (solo para primer arranque)
ALLOW_SETUP=true

# URL del frontend (necesaria en producción para CORS)
CLIENT_URL=http://localhost:5173